# ======================
# Hive — Environment Variables
# ======================
# Copy this file to .env and fill in the values.

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL Database
# Railway provides this automatically. For local dev, use your own Postgres URL.
DATABASE_URL=postgresql://username:password@localhost:5432/hive

# Session Secret (generate a random string — keep this private)
SESSION_SECRET=change-me-to-a-random-string

# Email Notifications (for application and inquiry forms)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google Drive API (for bulk image import from Drive folders)
GOOGLE_API_KEY=your-google-api-key

# Google Reviews Widget (homepage testimonials)
GOOGLE_PLACES_API_KEY=your-places-api-key
GOOGLE_PLACE_ID=your-google-place-id
