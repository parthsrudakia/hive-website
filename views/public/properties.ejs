<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Properties | Hive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #1a1a18;
  --cream: #f5f2ed;
  --warm: #e8e3db;
  --stone: #c4bdb3;
  --muted: #8a8378;
  --accent: #d4920b;
  --accent-dark: #b87d09;
  --accent-text: #9a6f08;
  --white: #fefdfb;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'DM Sans', -apple-system, sans-serif;
}

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--sans);
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ===== UTILITY ===== */
.container { max-width: 1280px; margin: 0 auto; padding: 0 clamp(24px, 5vw, 80px); }

/* ===== NAV ===== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 0;
  background: rgba(254,253,251,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(230,210,0,0.1);
  transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.nav .container {
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 12px; text-decoration: none;
  transform: scale(1.25); transform-origin: left center;
}
.nav-logo svg { flex-shrink: 0; }
.nav-logo .logo-text { display: flex; flex-direction: column; line-height: 1; }
.nav-logo .logo-name {
  font-family: var(--sans); font-weight: 700; font-size: 1.15rem;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink);
}
.nav-logo .logo-tag {
  font-family: var(--sans); font-size: 0.48rem; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase; margin-top: 6px;
  color: var(--ink); opacity: 0.5;
}
.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--accent-text); }
.nav-cta {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  border: 1px solid var(--accent-text) !important;
  color: var(--accent-text) !important;
  transition: all 0.3s !important;
}
.nav-cta:hover {}
.nav-login {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  background: var(--accent) !important;
  color: var(--ink) !important;
  transition: all 0.3s !important;
}
.nav-login:hover {}
.nav-cta-apply { background: var(--accent) !important; border-color: var(--accent) !important; color: var(--ink) !important; }
.nav-cta-apply:hover { background: var(--accent-dark) !important; border-color: var(--accent-dark) !important; }
.nav-mobile { display: none; background: none; border: none; cursor: pointer; }
.nav-mobile span {
  display: block; width: 24px; height: 1.5px; background: var(--ink);
  margin: 6px 0; transition: all 0.3s;
}

/* ===== PAGE HEADER ===== */
.page-header {
  padding-top: clamp(100px, 12vh, 140px);
  padding-bottom: clamp(28px, 3.5vw, 40px);
  background: var(--cream);
}
.page-header-inner {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.section-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-text);
  margin-bottom: 24px;
}
.section-tag::before {
  content: '';
  width: 32px; height: 1px;
  background: var(--accent-text);
}
.page-header h1 {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  font-weight: 300;
  line-height: 1.1;
}
.page-header h1 em {
  font-style: italic;
  color: var(--accent-text);
}
.page-header p {
  font-size: 1rem;
  font-weight: 300;
  color: var(--muted);
  margin-top: 16px;
  max-width: 480px;
  line-height: 1.7;
}

/* ===== BROWSE BAR ===== */
.browse-bar {
  padding: clamp(28px, 3vw, 44px);
  background: var(--white);
  display: flex;
  gap: 20px;
  align-items: flex-end;
  border-bottom: 1px solid var(--warm);
}
.browse-field {
  flex: 1;
}
.browse-field label {
  display: block;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}
.browse-field select,
.browse-field input {
  width: 100%;
  padding: 14px 16px;
  font-family: var(--sans);
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--ink);
  background: var(--white);
  border: 1px solid var(--stone);
  border-radius: 6px;
  appearance: none;
  -webkit-appearance: none;
  outline: none;
  cursor: pointer;
  transition: border-color 0.3s;
}
.browse-field select:focus,
.browse-field input:focus {
  border-color: var(--ink);
}
.browse-field select {
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%238a8378' stroke-width='1.2'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 16px center;
  padding-right: 40px;
}
/* Stay-date range picker (replaces the old Duration select) */
.browse-field-dates { flex: 1.6; }
.date-range {
  display: flex;
  gap: 8px;
}
.date-range input[type="date"] {
  flex: 1;
  min-width: 0;
  cursor: text;
}
.browse-btn {
  width: 100%;
  padding: 14px 16px;
  background: var(--ink);
  color: var(--white);
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: 1px solid var(--ink);
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.3s;
  white-space: nowrap;
  position: relative;
  z-index: 2;
  -webkit-tap-highlight-color: rgba(0,0,0,0.1);
}
.browse-btn:hover { background: #333330; }
.browse-btn:active { background: #333330; }
.label-hint {
  text-transform: none;
  letter-spacing: 0;
  font-weight: 400;
  color: var(--stone);
}
.stay-notice {
  display: flex;
  align-items: center;
  gap: 8px;
  margin: 14px 0 0;
  padding: 0 clamp(28px, 3vw, 44px);
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--accent-text);
}
.stay-notice[hidden] { display: none; }
.stay-notice svg { flex-shrink: 0; }

/* ===== PROPERTIES ===== */
.properties-section {
  padding: clamp(24px, 4vw, 40px) 0 clamp(60px, 8vw, 100px);
  background: var(--cream);
}
.properties-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: clamp(20px, 3vw, 32px);
}
.properties-count {
  font-size: 0.88rem;
  font-weight: 400;
  color: var(--muted);
}
.properties-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.property-card {
  position: relative;
  cursor: pointer;
}
.property-img {
  position: relative;
  aspect-ratio: 3/3.5;
  overflow: hidden;
  margin-bottom: 20px;
}
.property-img-inner {
  width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
  transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}
.property-card:hover .property-img-inner {
  transform: scale(1.05);
}
.property-img-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(26,26,24,0.4) 100%);
  opacity: 0;
  transition: opacity 0.4s;
}
.property-card:hover .property-img-overlay { opacity: 1; }
.property-badge {
  position: absolute;
  top: 16px; left: 16px;
  padding: 6px 14px;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.badge-available {
  background: var(--accent);
  color: var(--ink);
}
.badge-just-listed {
  background: var(--accent);
  color: var(--ink);
}
.badge-soon {
  background: var(--ink);
  color: var(--white);
}
.property-price {
  position: absolute;
  bottom: 16px; right: 16px;
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--white);
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.4s;
}
.property-card:hover .property-price {
  opacity: 1; transform: translateY(0);
}
.property-price span {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 400;
  color: rgba(255,255,255,0.7);
}
.property-info h3 {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 400;
  line-height: 1.35;
  margin-bottom: 6px;
  min-height: 3.375rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.property-meta {
  display: flex; align-items: center; gap: 16px;
  font-size: 0.78rem;
  font-weight: 400;
  color: var(--muted);
}
.property-meta span {
  display: flex; align-items: center; gap: 5px;
}
.property-meta .dot {
  width: 3px; height: 3px;
  border-radius: 0;
  background: var(--stone);
}
.property-amenities {
  display: flex;
  flex-wrap: wrap;
  gap: 7px 12px;
  margin-top: 12px;
}
.amenity-tag {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.72rem;
  font-weight: 400;
  color: var(--muted);
  white-space: nowrap;
}
.amenity-tag svg {
  width: 14px; height: 14px;
  color: var(--accent-text);
  flex-shrink: 0;
}

/* ===== FOOTER ===== */
.footer {
  padding: clamp(60px, 8vw, 100px) 0 40px;
  background: #141412;
}
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 60px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.footer-brand .nav-logo {
  display: flex;
  margin-bottom: 20px;
}
.footer-brand .nav-logo .logo-name { color: #fefdfb; }
.footer-brand .nav-logo .logo-tag { color: #fefdfb; }
.footer-brand p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,255,255,0.35);
  max-width: 320px;
  margin-bottom: 28px;
}

.footer-col h4 {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 24px;
}
.footer-col a {
  display: block;
  font-size: 0.88rem;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  margin-bottom: 14px;
  transition: color 0.3s;
}
.footer-col a:hover { color: var(--accent); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
}
.footer-bottom p {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
}
.footer-bottom a {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
  text-decoration: none;
}
.footer-bottom a:hover { color: var(--accent); }

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .properties-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .browse-bar { flex-wrap: wrap; }
  .browse-field { min-width: calc(50% - 10px); }
}
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-mobile { display: block; }
  .page-header-inner { flex-direction: column; align-items: flex-start; gap: 20px; }
  .properties-top { flex-direction: column; align-items: flex-start; gap: 16px; }
  .properties-grid { grid-template-columns: 1fr; }
  .footer-top { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  .browse-bar { flex-direction: column; }
  .browse-field { min-width: 100%; }
  .browse-btn { width: 100%; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container">
    <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
    <div class="nav-links">
      <a href="/properties">Properties</a>
      <a href="/partners">For Landlords</a>
      <a href="/#about">About</a>
      <a href="/partners/apply" class="nav-cta">Business Inquiry</a>
      <a href="/apply-now" class="nav-cta nav-cta-apply">Apply Now</a>
    </div>
    <button class="nav-mobile" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <div class="page-header-inner">
      <div>
        <div class="section-tag">Our Residences</div>
        <h1>Find your next <em>home.</em></h1>
        <p>Fully furnished, move-in ready apartments across the country. Flexible terms, no broker fees.</p>
      </div>
    </div>
  </div>
</section>

<!-- BROWSE / SEARCH -->
<div class="container">
  <div class="browse-bar reveal">
    <div class="browse-field">
      <label>Location</label>
      <select id="filter-location">
        <option value="">All Locations</option>
        <option value="New York">New York</option>
        <option value="Los Angeles">Los Angeles</option>
        <option value="Chicago">Chicago</option>
        <option value="Miami">Miami</option>
        <option value="San Francisco">San Francisco</option>
        <option value="Washington DC">Washington DC</option>
        <option value="Boston">Boston</option>
      </select>
    </div>
    <div class="browse-field">
      <label>Bedrooms</label>
      <select id="filter-bedrooms">
        <option value="">Any</option>
        <option value="0">Studio</option>
        <option value="1">1 Bedroom</option>
        <option value="2">2 Bedrooms</option>
        <option value="3">3+ Bedrooms</option>
      </select>
    </div>
    <div class="browse-field">
      <label>Price Range</label>
      <select id="filter-price">
        <option value="">Any Budget</option>
        <option value="0-3000">Under $3,000</option>
        <option value="3000-4500">$3,000 – $4,500</option>
        <option value="4500-6000">$4,500 – $6,000</option>
        <option value="6000-999999">$6,000+</option>
      </select>
    </div>
    <div class="browse-field browse-field-dates">
      <label>Stay Dates <span class="label-hint">(30 days minimum)</span></label>
      <div class="date-range">
        <input type="date" id="filter-movein" aria-label="Move-in date" title="Move-in date">
        <input type="date" id="filter-moveout" aria-label="Move-out date" title="Move-out date">
      </div>
    </div>
    <div class="browse-field">
      <label>&nbsp;</label>
      <button type="button" class="browse-btn" id="search-btn">Search</button>
    </div>
  </div>
  <p class="stay-notice" id="stay-notice" hidden>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 8v5M12 16.5v.5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/><circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.4"/></svg>
    Heads up: a minimum stay of 30 days is required.
  </p>
</div>

<!-- PROPERTIES -->
<section class="properties-section">
  <div class="container">
    <div class="properties-top">
      <p class="properties-count">Showing <%= listings.length %> properties</p>
    </div>
    <div class="properties-grid">
      <%
      // Format a DATE column as YYYY-MM-DD (local components) for the date filter; '' when unset.
      var fmtDate = function(d) {
        if (!d) return '';
        var dt = new Date(d);
        return dt.getFullYear() + '-' + String(dt.getMonth() + 1).padStart(2, '0') + '-' + String(dt.getDate()).padStart(2, '0');
      };
      // Fixed display order + icon/short-label for the 6 key amenity categories.
      var amenityOrder = ['In Unit Washer & Dryer', 'Gym', 'Pool', 'Parking', 'Lounge', 'Smart TV in Living Room'];
      var amenityMeta = {
        'In Unit Washer & Dryer': { short: 'In-Unit W/D', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><circle cx="12" cy="13" r="4"/><path d="M8 6h.01M11 6h.01"/></svg>' },
        'Gym': { short: 'Gym', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9v6M6 7v10M18 7v10M21 9v6M6 12h12"/></svg>' },
        'Pool': { short: 'Pool', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 15c2 0 2 1.6 4 1.6s2-1.6 4-1.6 2 1.6 4 1.6 2-1.6 4-1.6 2 1.6 4 1.6"/><path d="M2 19.5c2 0 2 1.6 4 1.6s2-1.6 4-1.6 2 1.6 4 1.6 2-1.6 4-1.6 2 1.6 4 1.6"/><path d="M8 12V5a2 2 0 014 0M16 12V5a2 2 0 00-4 0"/></svg>' },
        'Parking': { short: 'Parking', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h3.5a3 3 0 010 6H9"/></svg>' },
        'Lounge': { short: 'Lounge', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11V8a2 2 0 012-2h12a2 2 0 012 2v3"/><path d="M2 13a2 2 0 012 2v3h16v-3a2 2 0 012-2 2 2 0 00-2-2H4a2 2 0 00-2 2z"/><path d="M5 18v2M19 18v2"/></svg>' },
        'Smart TV in Living Room': { short: 'Smart TV', icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8"/></svg>' }
      };
      %>
      <% listings.forEach(function(listing) { %>
      <a href="/properties/<%= listing.id %>" class="property-card" style="text-decoration: none; color: inherit; display: block;" data-location="<%= listing.location || 'New York' %>" data-city="<%= listing.city %>" data-state="<%= listing.state %>" data-bedrooms="<%= listing.bedrooms %>" data-price="<%= listing.price_monthly %>" data-available-from="<%= fmtDate(listing.available_from) %>" data-available-to="<%= fmtDate(listing.available_to) %>">
        <div class="property-img">
          <% if (listing.images && listing.images.length > 0) { %>
          <div class="property-img-inner" style="background-image: url('<%= listing.images[0] %>'); background-size: cover; background-position: center;"></div>
          <% } else { %>
          <div class="property-img-inner" style="background: linear-gradient(145deg, #c4b8a8 0%, #a89888 40%, #8a7e6e 70%, #b8a898 100%);"></div>
          <% } %>
          <div class="property-img-overlay"></div>
          <% if (listing.status !== 'available') { %>
          <span class="property-badge <%= listing.status === 'just_listed' ? 'badge-just-listed' : 'badge-soon' %>"><%= listing.status === 'just_listed' ? 'Just Listed' : 'Coming Soon' %></span>
          <% } %>
          <span class="property-price">$<%= listing.price_monthly.toLocaleString() %><span> /month</span></span>
        </div>
        <div class="property-info">
          <h3><%= publicTitle(listing) %></h3>
          <div class="property-meta">
            <span><%= listing.neighborhood %>, <%= listing.city %></span>
            <span class="dot"></span>
            <span><%= listing.bedrooms === 0 ? 'Studio' : listing.bedrooms + ' Bed' %></span>
          </div>
          <% if (listing.key_amenities && listing.key_amenities.length) { %>
          <div class="property-amenities">
            <% amenityOrder.forEach(function(a) { if (listing.key_amenities.indexOf(a) === -1) return; var m = amenityMeta[a]; %>
            <span class="amenity-tag"><%- m.icon %><%= m.short %></span>
            <% }); %>
          </div>
          <% } %>
        </div>
      </a>
      <% }); %>
      <% if (listings.length === 0) { %>
      <div style="grid-column: 1/-1; text-align: center; padding: 60px 0; color: var(--muted);">
        <p style="font-size: 1.1rem;">No properties available at the moment. Check back soon!</p>
      </div>
      <% } %>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
        <p>Move-in ready, fully furnished with flexible lease terms. No broker fees, no guarantors required, no hidden fees.</p>
      </div>
      <div class="footer-col">
        <h4>Residences</h4>
        <% (locals.footerCities || []).forEach(function(city) { %>
        <a href="/properties?location=<%= encodeURIComponent(city) %>"><%= city %></a>
        <% }); %>
        <a href="/properties">All Properties</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/#about">About Us</a>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <a href="/contact">Contact Us</a>
        <a href="/faq">FAQ</a>
        <a href="/partners">Partner With Us</a>
        <a href="#">Terms of Service</a>
        <a href="#">Privacy Policy</a>
        <a href="/admin/login">Admin Login</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Hive. All rights reserved.</p>
      <a href="#">hello@hiveny.com</a>
    </div>
  </div>
</footer>

<script>
// Reveal on scroll
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
reveals.forEach(el => observer.observe(el));
// Fallback: reveal elements already in viewport on load
requestAnimationFrame(() => {
  reveals.forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
      el.classList.add('visible');
    }
  });
});

// Mobile nav
const mobileBtn = document.querySelector('.nav-mobile');
const navLinks = document.querySelector('.nav-links');
if (mobileBtn) {
  mobileBtn.addEventListener('click', () => {
    navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    if (navLinks.style.display === 'flex') {
      navLinks.style.position = 'absolute';
      navLinks.style.top = '100%';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(254,253,251,0.98)';
      navLinks.style.flexDirection = 'column';
      navLinks.style.padding = '24px clamp(24px, 5vw, 80px)';
      navLinks.style.gap = '20px';
      navLinks.querySelectorAll('a').forEach(a => a.style.setProperty('color', 'var(--ink)', 'important'));
    }
  });
}

// Search / Filter
function runSearch() {
  var loc = document.getElementById('filter-location').value;
  var bedrooms = document.getElementById('filter-bedrooms').value;
  var price = document.getElementById('filter-price').value;
  var moveIn = document.getElementById('filter-movein').value;   // YYYY-MM-DD or ''
  var moveOut = document.getElementById('filter-moveout').value; // YYYY-MM-DD or ''
  var cards = document.querySelectorAll('.property-card');
  var count = 0;

  cards.forEach(function(card) {
    var show = true;

    // Location filter
    if (loc && card.dataset.location !== loc) {
      show = false;
    }

    // Bedrooms filter
    if (bedrooms) {
      var cardBed = parseInt(card.dataset.bedrooms);
      var filterBed = parseInt(bedrooms);
      if (filterBed === 3) {
        if (cardBed < 3) show = false;
      } else {
        if (cardBed !== filterBed) show = false;
      }
    }

    // Price filter
    if (price) {
      var parts = price.split('-');
      var min = parseInt(parts[0]);
      var max = parseInt(parts[1]);
      var cardPrice = parseInt(card.dataset.price);
      if (cardPrice < min || cardPrice > max) show = false;
    }

    // Stay-dates filter: a room matches when its availability window covers the
    // requested stay. Date strings are YYYY-MM-DD, so string comparison is chronological.
    // An empty availability bound means open-ended (room shows for any dates).
    if (moveIn || moveOut) {
      var availFrom = card.dataset.availableFrom;
      var availTo = card.dataset.availableTo;
      if (moveIn) {
        if (availFrom && availFrom > moveIn) show = false; // not available until after move-in
        if (availTo && availTo < moveIn) show = false;     // window ends before move-in
      }
      if (moveOut) {
        if (availTo && availTo < moveOut) show = false;    // window ends before move-out
        if (availFrom && availFrom > moveOut) show = false;// window starts after move-out
      }
    }

    card.style.display = show ? '' : 'none';
    if (show) count++;

    // Carry the chosen stay dates onto the listing link so they pre-fill there.
    var base = card.getAttribute('href').split('?')[0];
    var params = [];
    if (moveIn) params.push('movein=' + encodeURIComponent(moveIn));
    if (moveOut) params.push('moveout=' + encodeURIComponent(moveOut));
    card.setAttribute('href', params.length ? base + '?' + params.join('&') : base);
  });

  // Update count
  var countEl = document.querySelector('.properties-count');
  if (countEl) {
    countEl.textContent = 'Showing ' + count + ' propert' + (count === 1 ? 'y' : 'ies');
  }
}
var searchBtn = document.getElementById('search-btn');
searchBtn.addEventListener('click', runSearch);
searchBtn.addEventListener('touchend', function(e) { e.preventDefault(); runSearch(); });

// Stay-date pickers: block past dates and enforce the 30-day minimum stay by
// keeping move-out at least 30 days after move-in.
(function() {
  var moveIn = document.getElementById('filter-movein');
  var moveOut = document.getElementById('filter-moveout');
  if (!moveIn || !moveOut) return;
  var notice = document.getElementById('stay-notice');
  var today = new Date().toISOString().slice(0, 10);
  // Add n days to a YYYY-MM-DD string, returning YYYY-MM-DD.
  function addDays(ymd, n) {
    var d = new Date(ymd + 'T00:00:00');
    d.setDate(d.getDate() + n);
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  }
  // Clamp move-out to the 30-day minimum; flash the heads-up if we had to correct it.
  function enforceMinStay() {
    var corrected = false;
    if (moveOut.value && moveOut.min && moveOut.value < moveOut.min) {
      moveOut.value = moveOut.min;
      corrected = true;
    }
    if (notice) notice.hidden = !corrected;
  }
  moveIn.min = today;
  moveOut.min = today;
  moveIn.addEventListener('change', function() {
    // Move-out must be at least 30 days after the chosen move-in date.
    moveOut.min = moveIn.value ? addDays(moveIn.value, 30) : today;
    enforceMinStay();
    runSearch();
  });
  moveOut.addEventListener('change', function() {
    enforceMinStay();
    runSearch();
  });
})();

// Pre-filter by location from the URL (e.g. /properties?location=Los%20Angeles)
(function() {
  var loc = new URLSearchParams(window.location.search).get('location');
  if (!loc) return;
  var sel = document.getElementById('filter-location');
  var match = Array.prototype.find.call(sel.options, function(o) { return o.value === loc; });
  if (!match) {
    // City not in the static dropdown (e.g. a new market) — add it so the
    // footer's dynamic city links always filter correctly.
    var opt = document.createElement('option');
    opt.value = loc;
    opt.textContent = loc;
    sel.appendChild(opt);
  }
  sel.value = loc;
  runSearch();
})();
</script>

</body>
</html>
