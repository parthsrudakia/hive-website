<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Partners | Hive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #1a1a18;
  --cream: #f5f2ed;
  --warm: #e8e3db;
  --stone: #c4bdb3;
  --muted: #8a8378;
  --accent: #d4920b;
  --accent-dark: #b87d09;
  --accent-text: #9a6f08;
  --white: #fefdfb;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'DM Sans', -apple-system, sans-serif;
}

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--sans);
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ===== UTILITY ===== */
.container { max-width: 1280px; margin: 0 auto; padding: 0 clamp(24px, 5vw, 80px); }

/* ===== NAV ===== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 0;
  background: rgba(254,253,251,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: none;
  transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.nav .container {
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 12px; text-decoration: none;
  transform: scale(1.25); transform-origin: left center;
}
.nav-logo svg { flex-shrink: 0; }
.nav-logo .logo-text { display: flex; flex-direction: column; line-height: 1; }
.nav-logo .logo-name {
  font-family: var(--sans); font-weight: 700; font-size: 1.15rem;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink);
}
.nav-logo .logo-tag {
  font-family: var(--sans); font-size: 0.48rem; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase; margin-top: 6px;
  color: var(--ink); opacity: 0.5;
}
.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--accent-text); }
.nav-cta {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  border: 1px solid var(--accent-text) !important;
  color: var(--accent-text) !important;
  transition: all 0.3s !important;
}
.nav-cta:hover {}
.nav-login {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  background: var(--accent) !important;
  color: var(--ink) !important;
  transition: all 0.3s !important;
}
.nav-login:hover {}
.nav-cta-apply { background: var(--accent) !important; border-color: var(--accent) !important; color: var(--ink) !important; }
.nav-cta-apply:hover { background: var(--accent-dark) !important; border-color: var(--accent-dark) !important; }
.nav-mobile { display: none; background: none; border: none; cursor: pointer; }
.nav-mobile span {
  display: block; width: 24px; height: 1.5px; background: var(--ink);
  margin: 6px 0; transition: all 0.3s;
}

/* ===== PAGE HEADER ===== */
.page-header {
  padding-top: clamp(140px, 16vh, 200px);
  padding-bottom: clamp(48px, 6vw, 80px);
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.page-header::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 60% 50% at 20% 30%, rgba(230,210,0,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 70%, rgba(230,210,0,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.page-header .container { position: relative; z-index: 2; }
.section-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-text);
  margin-bottom: 24px;
}
.section-tag::before {
  content: '';
  width: 32px; height: 1px;
  background: var(--accent-text);
}
.page-header .section-tag { color: var(--accent); }
.page-header .section-tag::before { background: var(--accent); }
.page-header h1 {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  font-weight: 300;
  line-height: 1.1;
  color: var(--white);
}
.page-header h1 em {
  font-style: italic;
  color: var(--accent);
}
.page-header p {
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  margin-top: 16px;
  max-width: 520px;
  line-height: 1.7;
}

/* ===== WHY PARTNER ===== */
.why-partner {
  padding: clamp(80px, 12vw, 140px) 0;
  background: var(--cream);
}
.why-partner-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: clamp(40px, 6vw, 100px);
  align-items: start;
}
.why-partner-left h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
  margin-bottom: 20px;
}
.why-partner-left h2 em { font-style: italic; color: var(--accent-text); }
.why-partner-left > p {
  font-size: 1rem;
  font-weight: 300;
  line-height: 1.8;
  color: var(--muted);
}
.why-partner-right {}
.benefit-item {
  padding: 28px 0;
  border-bottom: 1px solid rgba(196,189,179,0.3);
  display: flex;
  gap: 20px;
  align-items: flex-start;
}
.benefit-item:first-child {
  border-top: 1px solid rgba(196,189,179,0.3);
}
.benefit-item h4 {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 6px;
}
.benefit-item p {
  font-size: 0.9rem;
  font-weight: 300;
  line-height: 1.7;
  color: var(--muted);
}

/* ===== HOW IT WORKS ===== */
.how-it-works {
  padding: clamp(80px, 12vw, 140px) 0;
  background: var(--white);
}
.how-header {
  text-align: center;
  margin-bottom: clamp(48px, 6vw, 80px);
}
.how-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
}
.how-header h2 em { font-style: italic; color: var(--accent-text); }
.how-header p {
  font-size: 1rem;
  font-weight: 300;
  color: var(--muted);
  max-width: 540px;
  margin: 20px auto 0;
  line-height: 1.7;
}
.steps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
}
.step-card {
  padding: clamp(32px, 3vw, 48px);
  border-right: 1px solid var(--warm);
  position: relative;
}
.step-card:last-child { border-right: none; }
.step-num {
  font-family: var(--serif);
  font-size: 3rem;
  font-weight: 300;
  color: var(--ink);
  line-height: 1;
  margin-bottom: 24px;
}
.step-card h3 {
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 12px;
}
.step-card p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.75;
  color: var(--muted);
}

/* ===== CTA BAND ===== */
.cta-band {
  padding: clamp(48px, 6vw, 72px) 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.cta-band::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 50% 50% at 50% 50%, rgba(230,210,0,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.cta-band .container {
  position: relative; z-index: 2;
  display: flex; align-items: center; justify-content: space-between; gap: 40px;
}
.cta-band-text { flex: 1; }
.cta-band h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 300;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 8px;
}
.cta-band h2 em { font-style: italic; color: var(--accent); }
.cta-band p {
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  max-width: 480px;
  line-height: 1.7;
  margin-bottom: 0;
}
@media (max-width: 768px) {
  .cta-band .container { flex-direction: column; text-align: center; gap: 24px; }
  .cta-band p { margin-left: auto; margin-right: auto; }
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 36px;
  background: var(--accent);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.btn-primary:hover {}
.btn-primary svg { transition: transform 0.3s; }
.btn-primary:hover svg {}

/* ===== FOOTER ===== */
.footer {
  padding: clamp(60px, 8vw, 100px) 0 40px;
  background: #141412;
}
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 60px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.footer-brand .nav-logo {
  display: flex;
  margin-bottom: 20px;
}
.footer-brand .nav-logo .logo-name { color: #fefdfb; }
.footer-brand .nav-logo .logo-tag { color: #fefdfb; }
.footer-brand p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,255,255,0.35);
  max-width: 320px;
  margin-bottom: 28px;
}

.footer-col h4 {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 24px;
}
.footer-col a {
  display: block;
  font-size: 0.88rem;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  margin-bottom: 14px;
  transition: color 0.3s;
}
.footer-col a:hover { color: var(--accent); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
}
.footer-bottom p {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
}
.footer-bottom a {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
  text-decoration: none;
}
.footer-bottom a:hover { color: var(--accent); }

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .why-partner-inner { grid-template-columns: 1fr; }
  .steps-grid { grid-template-columns: repeat(2, 1fr); }
  .step-card { border-bottom: 1px solid var(--warm); }
  .step-card:nth-child(2) { border-right: none; }
  .footer-top { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-mobile { display: block; }
  .steps-grid { grid-template-columns: 1fr; }
  .step-card { border-right: none; }
  .footer-top { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container">
    <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
    <div class="nav-links">
      <a href="/properties">Properties</a>
      <a href="/partners">For Landlords</a>
      <a href="/#about">About</a>
      <a href="/partners/apply" class="nav-cta">Business Inquiry</a>
      <a href="/apply-now" class="nav-cta nav-cta-apply">Apply Now</a>
    </div>
    <button class="nav-mobile" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <div class="section-tag">For Landlords</div>
    <h1>Increase your rental <em>income.</em></h1>
    <p>Take advantage of Hive's proven rental solutions to effectively market and manage your properties, resulting in cost reduction and minimized risk.</p>
  </div>
</section>

<!-- WHY PARTNER -->
<section class="why-partner">
  <div class="container">
    <div class="why-partner-inner reveal">
      <div class="why-partner-left">
        <h2>The Hive Partner<br><em>Advantage.</em></h2>
        <p>A turnkey partnership designed to enhance income, stabilize occupancy, and remove day-to-day management burden, all backed by Hive's proven framework.</p>
      </div>
      <div class="why-partner-right">
        <div class="benefit-item">
          <div>
            <h4>Reliable Long-Term Cash Flow</h4>
            <p>Our approach eliminates vacancies, providing a guarantee of consistent rental income at full market rent.</p>
          </div>
        </div>
        <div class="benefit-item">
          <div>
            <h4>Screened & Qualified Residents</h4>
            <p>Hive manages the screening and financial qualification of every resident, so you can enjoy consistent income without the traditional tenant headaches.</p>
          </div>
        </div>
        <div class="benefit-item">
          <div>
            <h4>Reduced Operational Costs</h4>
            <p>We minimize turnover, maintenance, and marketing costs so you keep more of your rental income.</p>
          </div>
        </div>
        <div class="benefit-item">
          <div>
            <h4>Seamless Tenant Support</h4>
            <p>Our tenant communication hub allows for faster and personalized responses, keeping your residents happy.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-it-works">
  <div class="container">
    <div class="how-header reveal">
      <h2>Our Simple <em>Process.</em></h2>
      <p>A seamless onboarding process from consultation to full management.</p>
    </div>
    <div class="steps-grid reveal">
      <div class="step-card">
        <div class="step-num">01</div>
        <h3>Provide Property Details</h3>
        <p>Share your property overview details through our simple form. We'll review the location, layout, and potential.</p>
      </div>
      <div class="step-card">
        <div class="step-num">02</div>
        <h3>Receive Custom Proposal</h3>
        <p>Our onboarding team prepares a customized proposal tailored to your property and its earning potential.</p>
      </div>
      <div class="step-card">
        <div class="step-num">03</div>
        <h3>Review & Sign Agreement</h3>
        <p>Review the process, ask questions, and sign your partnership agreement. We're here to answer everything.</p>
      </div>
      <div class="step-card">
        <div class="step-num">04</div>
        <h3>Hive Manages Everything</h3>
        <p>We handle advertising, leasing, and tenant relations from day one. Sit back and collect your monthly income.</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-band">
  <div class="container reveal">
    <div class="cta-band-text">
      <h2>Ready to <em>get started?</em></h2>
      <p>Submit your property details and our partnerships team will reach out with a customized proposal.</p>
    </div>
    <a href="/partners/apply" class="btn-primary">
      Get Started
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.3"/></svg>
    </a>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
        <p>Move-in ready, fully furnished with flexible lease terms. No broker fees, no guarantors required, no hidden fees.</p>
      </div>
      <div class="footer-col">
        <h4>Residences</h4>
        <% (locals.footerCities || []).forEach(function(city) { %>
        <a href="/properties?location=<%= encodeURIComponent(city) %>"><%= city %></a>
        <% }); %>
        <a href="/properties">All Properties</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/#about">About Us</a>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <a href="/contact">Contact Us</a>
        <a href="/faq">FAQ</a>
        <a href="/partners">Partner With Us</a>
        <a href="#">Terms of Service</a>
        <a href="#">Privacy Policy</a>
        <a href="/admin/login">Admin Login</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Hive. All rights reserved.</p>
      <a href="#">hello@hiveny.com</a>
    </div>
  </div>
</footer>

<script>
// Reveal on scroll
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
reveals.forEach(el => observer.observe(el));

// Mobile nav
const mobileBtn = document.querySelector('.nav-mobile');
const navLinks = document.querySelector('.nav-links');
if (mobileBtn) {
  mobileBtn.addEventListener('click', () => {
    navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    if (navLinks.style.display === 'flex') {
      navLinks.style.position = 'absolute';
      navLinks.style.top = '100%';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(254,253,251,0.98)';
      navLinks.style.flexDirection = 'column';
      navLinks.style.padding = '24px clamp(24px, 5vw, 80px)';
      navLinks.style.gap = '20px';
      navLinks.querySelectorAll('a').forEach(a => a.style.setProperty('color', 'var(--ink)', 'important'));
    }
  });
}
</script>

</body>
</html>
