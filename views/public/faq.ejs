<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FAQ | Hive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #1a1a18;
  --cream: #f5f2ed;
  --warm: #e8e3db;
  --stone: #c4bdb3;
  --muted: #8a8378;
  --accent: #d4920b;
  --accent-dark: #b87d09;
  --accent-text: #9a6f08;
  --white: #fefdfb;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'DM Sans', -apple-system, sans-serif;
}

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--sans);
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

.container { max-width: 1280px; margin: 0 auto; padding: 0 clamp(24px, 5vw, 80px); }

/* ===== NAV ===== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 0;
  background: rgba(254,253,251,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: none;
  transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.nav .container {
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 12px; text-decoration: none;
  transform: scale(1.25); transform-origin: left center;
}
.nav-logo svg { flex-shrink: 0; }
.nav-logo .logo-text { display: flex; flex-direction: column; line-height: 1; }
.nav-logo .logo-name {
  font-family: var(--sans); font-weight: 700; font-size: 1.15rem;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink);
}
.nav-logo .logo-tag {
  font-family: var(--sans); font-size: 0.48rem; font-weight: 500;
  letter-spacing: 0.14em; text-transform: uppercase; margin-top: 6px;
  color: var(--ink); opacity: 0.5;
}
.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--accent-text); }
.nav-cta {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  border: 1px solid var(--accent-text) !important;
  color: var(--accent-text) !important;
  transition: all 0.3s !important;
}
.nav-cta-apply { background: var(--accent) !important; border-color: var(--accent) !important; color: var(--ink) !important; }
.nav-cta-apply:hover { background: var(--accent-dark) !important; border-color: var(--accent-dark) !important; }
.nav-mobile { display: none; background: none; border: none; cursor: pointer; }
.nav-mobile span {
  display: block; width: 24px; height: 1.5px; background: var(--ink);
  margin: 6px 0; transition: all 0.3s;
}

/* ===== PAGE HEADER ===== */
.page-header {
  padding-top: clamp(140px, 16vh, 200px);
  padding-bottom: clamp(48px, 6vw, 80px);
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.page-header::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 60% 50% at 20% 30%, rgba(230,210,0,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 70%, rgba(230,210,0,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.page-header .container { position: relative; z-index: 2; }
.section-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 24px;
}
.section-tag::before {
  content: '';
  width: 32px; height: 1px;
  background: var(--accent);
}
.page-header h1 {
  font-family: var(--serif);
  font-size: clamp(2.4rem, 4.5vw, 4rem);
  font-weight: 300;
  line-height: 1.1;
  color: var(--white);
}
.page-header h1 em {
  font-style: italic;
  color: var(--accent);
}
.page-header p {
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  margin-top: 16px;
  max-width: 520px;
  line-height: 1.7;
}

/* ===== FAQ ===== */
.faq-section {
  padding: clamp(60px, 8vw, 100px) 0;
}
.faq-inner {
  max-width: 760px;
  margin: 0 auto;
}
.faq-item {
  border-bottom: 1px solid var(--warm);
}
.faq-item:first-child {
  border-top: 1px solid var(--warm);
}
.faq-question {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 400;
  color: var(--ink);
  text-align: left;
  transition: color 0.3s;
}
.faq-question:hover { color: var(--accent-text); }
.faq-question svg {
  flex-shrink: 0;
  margin-left: 16px;
  transition: transform 0.3s;
}
.faq-item.active .faq-question svg {
  transform: rotate(180deg);
}
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.faq-item.active .faq-answer {
  max-height: 260px;
}
.faq-answer p {
  padding: 0 0 24px;
  font-size: 0.92rem;
  font-weight: 300;
  line-height: 1.75;
  color: var(--muted);
  max-width: 640px;
}
.faq-contact {
  margin-top: 48px;
  text-align: center;
}
.faq-contact p {
  font-size: 0.92rem;
  font-weight: 300;
  color: var(--muted);
  margin-bottom: 20px;
}
.faq-contact a {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  font-family: var(--sans);
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--ink);
  background: var(--accent);
  text-decoration: none;
  transition: all 0.3s;
}
.faq-contact a:hover { background: var(--accent-dark); }

/* ===== FOOTER ===== */
.footer {
  padding: clamp(48px, 6vw, 80px) 0 40px;
  background: var(--ink);
}
.footer-top {
  display: grid;
  grid-template-columns: 1.5fr repeat(3, 1fr);
  gap: 48px;
  padding-bottom: 32px;
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.footer-brand .nav-logo {
  display: flex;
  margin-bottom: 20px;
}
.footer-brand p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,255,255,0.35);
  max-width: 320px;
  margin-bottom: 28px;
}
.footer-col h4 {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 24px;
}
.footer-col a {
  display: block;
  font-size: 0.88rem;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  margin-bottom: 14px;
  transition: color 0.3s;
}
.footer-col a:hover { color: var(--accent); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
}
.footer-bottom p {
  font-size: 0.78rem;
  font-weight: 300;
  color: rgba(255,255,255,0.25);
}
.footer-bottom a {
  font-size: 0.78rem;
  font-weight: 300;
  color: rgba(255,255,255,0.25);
  text-decoration: none;
}
.footer .nav-logo .logo-name { color: #fefdfb; }
.footer .nav-logo .logo-tag { color: #fefdfb; }

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav-mobile { display: block; }
  .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <div class="container">
    <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
    <div class="nav-links">
      <a href="/properties">Properties</a>
      <a href="/partners">For Landlords</a>
      <a href="/#about">About</a>
      <a href="/partners" class="nav-cta">Business Inquiry</a>
      <a href="/apply-now" class="nav-cta nav-cta-apply">Apply Now</a>
    </div>
    <button class="nav-mobile" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- PAGE HEADER -->
<section class="page-header">
  <div class="container">
    <div class="section-tag">FAQ</div>
    <h1>Frequently Asked <em>Questions.</em></h1>
    <p>Everything you need to know about renting with Hive. Can't find your answer? Reach out and we'll be happy to help.</p>
  </div>
</section>

<!-- FAQ LIST -->
<section class="faq-section">
  <div class="container">
    <div class="faq-inner">
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            <span>What is Hive?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>Hive offers move-in ready, fully furnished apartments with flexible lease terms. Every home is professionally cleaned and set up before you arrive — just bring your suitcase.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What's the minimum stay?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>Our minimum stay is 30 days. Beyond that, leases are month-to-month, so you can stay for a season or settle in for a year — whatever fits your plans.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>What's included in the monthly rent?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>Your rent covers everything: fully furnished apartment, WiFi, utilities (electric, gas, water), and building amenities. There are no hidden fees, broker fees, or security deposits beyond the first month.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Do I need a guarantor or broker?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>No. There are no guarantors required and no broker fees. Apply online, and once you're approved we'll schedule your move-in date.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>How does the move-in process work?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>Once you're approved, we'll schedule your move-in date. On the day, you'll receive a welcome package with keys and WiFi info. Every apartment is professionally cleaned and fully furnished.</p>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            <span>Can I extend my stay?</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.3"/></svg>
          </button>
          <div class="faq-answer">
            <p>Absolutely. Our leases are month-to-month, so you can extend your stay for as long as you'd like.</p>
          </div>
        </div>
      </div>
      <div class="faq-contact">
        <p>Still have a question? We're happy to help.</p>
        <a href="/contact">Contact Us <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.3"/></svg></a>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="nav-logo">
              <svg width="24" height="30" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="8" r="4.5" fill="#d4920b"/><rect x="28" y="18" width="24" height="6" rx="3" fill="#d4920b"/><rect x="18" y="32" width="44" height="6" rx="3" fill="#d4920b"/><rect x="15" y="46" width="50" height="6" rx="3" fill="#d4920b"/><rect x="18" y="60" width="44" height="6" rx="3" fill="#d4920b"/><rect x="28" y="74" width="24" height="6" rx="3" fill="#d4920b"/><circle cx="40" cy="88" r="4" fill="#d4920b"/></svg>
              <div class="logo-text"><span class="logo-name">Hive</span><span class="logo-tag">City Living, Made Simple</span></div>
            </a>
        <p>Move-in ready, fully furnished with flexible lease terms. No broker fees, no guarantors required, no hidden fees.</p>
      </div>
      <div class="footer-col">
        <h4>Residences</h4>
        <% (locals.footerCities || []).forEach(function(city) { %>
        <a href="/properties?location=<%= encodeURIComponent(city) %>"><%= city %></a>
        <% }); %>
        <a href="/properties">All Properties</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/#about">About Us</a>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <a href="/contact">Contact Us</a>
        <a href="/faq">FAQ</a>
        <a href="/partners">Partner With Us</a>
        <a href="#">Terms of Service</a>
        <a href="#">Privacy Policy</a>
        <a href="/admin/login">Admin Login</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Hive. All rights reserved.</p>
      <a href="#">hello@hiveny.com</a>
    </div>
  </div>
</footer>

<script>
// Mobile nav toggle
const navMobile = document.querySelector('.nav-mobile');
const navLinks = document.querySelector('.nav-links');
if (navMobile) {
  navMobile.addEventListener('click', () => {
    if (navLinks.style.display === 'flex') {
      navLinks.style.display = 'none';
    } else {
      navLinks.style.display = 'flex';
      navLinks.style.position = 'absolute';
      navLinks.style.top = '100%';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(254,253,251,0.98)';
      navLinks.style.flexDirection = 'column';
      navLinks.style.padding = '24px clamp(24px, 5vw, 80px)';
      navLinks.style.gap = '20px';
    }
  });
}

// FAQ accordion
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.parentElement;
    const wasActive = item.classList.contains('active');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
    if (!wasActive) item.classList.add('active');
  });
});
</script>
</body>
</html>
