}
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 48px;
  padding-bottom: 60px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
}
.footer-brand {}
.footer-brand .nav-logo {
  display: flex;
  margin-bottom: 20px;
}
.footer-brand .nav-logo .logo-name { color: #fefdfb; }
.footer-brand .nav-logo .logo-tag { color: #fefdfb; }
.footer-brand p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,255,255,0.35);
  max-width: 320px;
  margin-bottom: 28px;
}

.footer-col h4 {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 24px;
}
.footer-col a {
  display: block;
  font-size: 0.88rem;
  font-weight: 300;
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  margin-bottom: 14px;
  transition: color 0.3s;
}
.footer-col a:hover { color: var(--accent); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 32px;
}
.footer-bottom p {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
}
.footer-bottom a {
  font-size: 0.75rem;
  font-weight: 400;
  color: rgba(255,255,255,0.2);
  text-decoration: none;
}
.footer-bottom a:hover { color: var(--accent); }

/* ===== FAQ ===== */
.faq-section {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--ink);
}
.faq-inner {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: clamp(40px, 6vw, 100px);
  align-items: start;
}
.faq-header {
  position: sticky;
  top: 120px;
}
.faq-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
  color: var(--white);
}
.faq-header h2 em { font-style: italic; color: var(--accent); }
.faq-list {
  max-width: none;
}
.faq-item {
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.faq-item:first-child {
  border-top: 1px solid rgba(255,255,255,0.1);
}
.faq-question {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: var(--serif);
  font-size: 1.15rem;
  font-weight: 400;
  color: rgba(255,255,255,0.9);
  text-align: left;
  transition: color 0.3s;
}
.faq-question:hover { color: var(--accent); }
.faq-question svg {
  flex-shrink: 0;
  margin-left: 16px;
  transition: transform 0.3s;
}
.faq-item.active .faq-question svg {
  transform: rotate(180deg);
}
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.faq-item.active .faq-answer {
  max-height: 200px;
}
.faq-answer p {
  padding: 0 0 24px;
  font-size: 0.92rem;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(255,255,255,0.5);
}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
  .fp-grid { grid-template-columns: repeat(2, 1fr); }
  .fp-grid .fp-card:last-child { display: none; }
  .properties-grid { grid-template-columns: repeat(2, 1fr); }
  .testimonial-card { flex: 0 0 300px; }
  .about-grid { grid-template-columns: 1fr; }
  .about-col-main { grid-column: 1; }
  .footer-top { grid-template-columns: 1fr 1fr; }
  .hero-stats { display: none; }
  .browse-bar { flex-wrap: wrap; }
  .browse-field { min-width: calc(50% - 10px); }
}
@media (max-width: 768px) {
  .fp-title { font-size: clamp(1.4rem, 5vw, 1.8rem); white-space: nowrap; }
