/* ===== ABOUT FULL ===== */
.about-section {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--white);
}
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 48px;
}
.about-col-main {
  grid-column: 1 / 3;
}
.about-col-main h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 28px;
}
.about-col-main h2 em { font-style: italic; color: var(--accent-text); }
.about-col-main p {
  font-size: 1rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--muted);
  margin-bottom: 16px;
}
.about-col-side {
  padding-top: 8px;
}
.about-values { list-style: none; }
.about-values li {
  padding: 20px 0;
  border-bottom: 1px solid rgba(196,189,179,0.3);
}
.about-values li:first-child { border-top: 1px solid rgba(196,189,179,0.3); }
.about-values li h4 {
  font-family: var(--serif);
  font-size: 1.15rem;
  font-weight: 400;
  margin-bottom: 6px;
}
.about-values li p {
  font-size: 0.82rem;
  font-weight: 300;
  color: var(--muted);
  line-height: 1.6;
}

/* ===== CTA BAND ===== */
.cta-band {
  padding: 28px 0;
  background: var(--ink);
}
.cta-band .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.cta-band-text {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
  min-width: 0;
}
.cta-band h2 {
  font-family: var(--serif);
  font-size: clamp(1.2rem, 2vw, 1.6rem);
  font-weight: 300;
  color: var(--white);
