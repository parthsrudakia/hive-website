  border: 1px solid var(--warm);
  transition: all 0.4s;
  display: flex;
  flex-direction: column;
}
.testimonial-stars {
  display: flex; gap: 3px;
  margin-bottom: 24px;
}
.testimonial-stars svg { width: 14px; height: 14px; fill: var(--accent); }
.testimonial-card blockquote {
  font-family: var(--serif);
  font-size: 1.05rem;
  font-weight: 300;
  font-style: italic;
  line-height: 1.7;
  color: var(--ink);
  margin-bottom: 28px;
}
.testimonial-author {
  display: flex; align-items: center; gap: 14px;
  margin-top: auto;
}
.testimonial-avatar {
  width: 40px; height: 40px;
  border-radius: 50%;
  background: var(--warm);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.testimonial-avatar svg {
  width: 20px; height: 20px;
  fill: var(--muted);
}
.testimonial-author-info h4 {
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--ink);
}
.testimonial-author-info p {
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--muted);
  margin-top: 2px;
}
.carousel-indicators {
  display: flex;
  justify-content: center;
  gap: 6px;
  margin-top: 36px;
}
.carousel-dot {
  width: 40px; height: 3px;
  border-radius: 2px;
  background: var(--warm);
  border: none;
  padding: 0;
  cursor: pointer;
  transition: all 0.3s;
}
.carousel-dot.active {
  background: var(--ink);
}
/* ===== PARTNERS / INVESTORS ===== */
.partners-section {
  padding: clamp(48px, 6vw, 80px) 0;
