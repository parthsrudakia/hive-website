<script>
// Testimonial banner carousel
(function() {
  <% if (typeof googleReviews !== 'undefined' && googleReviews.reviews && googleReviews.reviews.length > 0) { %>
  const quotes = <%- JSON.stringify(googleReviews.reviews.map(function(r) { return { name: r.author, text: '\u201C' + r.text.substring(0, 150) + (r.text.length > 150 ? '...' : '') + '\u201D', avatar: r.avatar || '' }; })) %>;
  <% } else { %>
  const quotes = [
    { name: 'Alexandra Aiah', text: '\u201CGreat experience and very attentive to requests or when issues came up.\u201D', avatar: '/images/alexandra.png' },
    { name: 'Dillon Del Toro', text: '\u201CIt\u2019s rare to find a landlord who genuinely cares about their tenants and takes pride in maintaining their properties.\u201D', avatar: '/images/dillon.jpg' },
    { name: 'Sajan George', text: '\u201CHive made it easy and less stressful \u2014 I would recommend it to anyone.\u201D', avatar: '/images/sajan.png' },
    { name: 'Will OConnell', text: '\u201CSuper easy process, I had an amazing stay with a very nice room. Always super easy to get in contact when needed!\u201D', avatar: '/images/will.jpg' },
    { name: 'Daniela Hoyos', text: '\u201CI\u2019ve had an excellent experience renting from Vinny. This is the second apartment of his that I\u2019ve lived in.\u201D', avatar: '/images/daniela.jpg' },
    { name: 'Eileen Lee', text: '\u201CAmazing experience!! Everything was seamless from start to finish.\u201D', avatar: '/images/eileen.png' },
    { name: 'Clara Falxa', text: '\u201CAmazing stay! The apartments are always super nice and have plenty of amenities. Vinny is very responsive.\u201D', avatar: '/images/clara.jpg' },
    { name: 'Savera Bhatnagar', text: '\u201CLove Hive and their customer service. I have been staying in their units for almost 2 yrs.\u201D', avatar: '/images/savera.jpg' }
  ];
  <% } %>
  let idx = 0;
  const nameEl = document.getElementById('tb-name');
  const textEl = document.getElementById('tb-text');
  const avatarEl = document.getElementById('tb-avatar');
  const prevBtn = document.getElementById('tb-prev');
  const nextBtn = document.getElementById('tb-next');
  if (!nameEl || !textEl) return;
  function show(i) {
    idx = (i + quotes.length) % quotes.length;
    nameEl.textContent = quotes[idx].name;
    textEl.textContent = quotes[idx].text;
    if (avatarEl && quotes[idx].avatar) { avatarEl.src = quotes[idx].avatar; avatarEl.alt = quotes[idx].name; }
  }
  // Auto-rotate every 5 seconds
  let autoTimer = setInterval(() => show(idx + 1), 5000);
  function resetTimer() { clearInterval(autoTimer); autoTimer = setInterval(() => show(idx + 1), 5000); }
  if (prevBtn) prevBtn.addEventListener('click', () => { show(idx - 1); resetTimer(); });
  if (nextBtn) nextBtn.addEventListener('click', () => { show(idx + 1); resetTimer(); });
})();

// Nav scroll
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
});

// Reveal on scroll
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.05, rootMargin: '0px 0px 50px 0px' });
reveals.forEach(el => observer.observe(el));
// Fallback: reveal elements already in viewport on load
requestAnimationFrame(() => {
  reveals.forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight) {
      el.classList.add('visible');
    }
  });
});


// Card image carousels — touch swipe only (mobile)
if (window.matchMedia('(max-width: 768px)').matches) {
  document.querySelectorAll('.fp-card-img').forEach(card => {
    const slides = card.querySelector('.fp-card-slides');
    const imgs = card.querySelectorAll('.fp-card-img-inner');
    const dots = card.querySelectorAll('.fp-slide-dot');
    if (!slides || imgs.length <= 1) return;
    let idx = 0;
    let startX = 0;
    let startY = 0;
    let isDragging = false;

    function go(i) {
      idx = (i + imgs.length) % imgs.length;
      slides.style.transform = 'translateX(-' + (idx * 100) + '%)';
      dots.forEach((d, j) => d.classList.toggle('active', j === idx));
    }

    card.addEventListener('touchstart', function(e) {
      startX = e.touches[0].clientX;
      startY = e.touches[0].clientY;
      isDragging = true;
    }, { passive: true });

    card.addEventListener('touchmove', function(e) {
      if (!isDragging) return;
      var diffX = e.touches[0].clientX - startX;
      var diffY = e.touches[0].clientY - startY;
      if (Math.abs(diffX) > Math.abs(diffY) && Math.abs(diffX) > 10) {
        e.preventDefault();
      }
    }, { passive: false });

    card.addEventListener('touchend', function(e) {
      if (!isDragging) return;
      isDragging = false;
      var endX = e.changedTouches[0].clientX;
      var diffX = endX - startX;
      var threshold = 40;
      if (diffX < -threshold) {
        go(idx + 1);
      } else if (diffX > threshold) {
        go(idx - 1);
      }
    }, { passive: true });
  });
}

// Testimonials carousel indicators
(function() {
  const grid = document.querySelector('.testimonials-grid');
  const dotsContainer = document.getElementById('testimonial-dots');
  if (!grid || !dotsContainer) return;
  const cards = grid.querySelectorAll('.testimonial-card');
  const perPage = 3;
  const totalPages = Math.ceil(cards.length / perPage);
  for (let i = 0; i < totalPages; i++) {
    const dot = document.createElement('button');
    dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', 'Page ' + (i + 1));
    dot.addEventListener('click', () => {
      const card = cards[i * perPage];
      if (card) grid.scrollTo({ left: card.offsetLeft - grid.offsetLeft, behavior: 'smooth' });
    });
    dotsContainer.appendChild(dot);
  }
  let currentPage = 0;
  function updateDots() {
    dotsContainer.querySelectorAll('.carousel-dot').forEach((d, i) => {
      d.classList.toggle('active', i === currentPage);
    });
  }
  function scrollToPage(page) {
    currentPage = Math.max(0, Math.min(page, totalPages - 1));
    const card = cards[currentPage * perPage];
    if (card) grid.scrollTo({ left: card.offsetLeft - grid.offsetLeft, behavior: 'smooth' });
    updateDots();
  }
  grid.addEventListener('scroll', () => {
    const cardWidth = cards[0].offsetWidth + 20;
    currentPage = Math.round(grid.scrollLeft / (cardWidth * perPage));
    updateDots();
  });
})();

// FAQ accordion
document.querySelectorAll('.faq-question').forEach(btn => {
  btn.addEventListener('click', () => {
    const item = btn.parentElement;
    const isActive = item.classList.contains('active');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('active'));
    if (!isActive) item.classList.add('active');
  });
});

// Mobile nav
const mobileBtn = document.querySelector('.nav-mobile');
const navLinks = document.querySelector('.nav-links');
if (mobileBtn) {
  mobileBtn.addEventListener('click', () => {
    navLinks.style.display = navLinks.style.display === 'flex' ? 'none' : 'flex';
    if (navLinks.style.display === 'flex') {
      navLinks.style.position = 'absolute';
      navLinks.style.top = '100%';
      navLinks.style.left = '0';
      navLinks.style.right = '0';
      navLinks.style.background = 'rgba(254,253,251,0.98)';
      navLinks.style.flexDirection = 'column';
      navLinks.style.padding = '24px clamp(24px, 5vw, 80px)';
      navLinks.style.gap = '20px';
      navLinks.querySelectorAll('a').forEach(a => {
        if (a.classList.contains('nav-cta')) {
          a.style.setProperty('color', 'var(--ink)', 'important');
          a.style.setProperty('border', '1px solid var(--ink)', 'important');
        } else {
          a.style.color = 'var(--ink)';
        }
      });
    }
  });
}
</script>

