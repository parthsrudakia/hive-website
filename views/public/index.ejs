<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hive | City Living, Made Simple</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --ink: #1a1a18;
  --cream: #f5f2ed;
  --warm: #e8e3db;
  --stone: #c4bdb3;
  --muted: #8a8378;
  --accent: #d4920b;
  --accent-dark: #b87d09;
  --accent-text: #9a6f08;
  --white: #fefdfb;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'DM Sans', -apple-system, sans-serif;
}

html { scroll-behavior: smooth; font-size: 16px; }

body {
  font-family: var(--sans);
  color: var(--ink);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ===== UTILITY ===== */
.container { max-width: 1280px; margin: 0 auto; padding: 0 clamp(24px, 5vw, 80px); }
.sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }

/* ===== NAV ===== */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 20px 0;
  transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.nav.scrolled { top: 0; }
.nav.scrolled {
  background: rgba(254,253,251,0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(230,210,0,0.1);
  padding: 14px 0;
}
.nav .container {
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 12px;
  text-decoration: none;
  transition: color 0.4s;
  transform: scale(1.25);
  transform-origin: left center;
}
.nav-logo svg { flex-shrink: 0; }
.nav-logo .logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1;
}
.nav-logo .logo-name {
  font-family: var(--sans);
  font-weight: 700;
  font-size: 1.15rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--white);
  transition: color 0.4s;
}
.nav.scrolled .nav-logo .logo-name { color: var(--ink); }
.nav-logo .logo-tag {
  font-family: var(--sans);
  font-size: 0.48rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-top: 6px;
  color: var(--white);
  opacity: 0.5;
  transition: color 0.4s;
}
.nav.scrolled .nav-logo .logo-tag { color: var(--ink); }
/* SVG fill transitions */
.nav-logo .nav-icon-light { display: none; }
.nav-logo .nav-icon-dark { display: block; }
.nav.scrolled .nav-logo .nav-icon-light { display: block; }
.nav.scrolled .nav-logo .nav-icon-dark { display: none; }
/* Yellow accent strip at top */
.top-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 101;
  background: var(--accent);
  padding: 8px 0;
  text-align: center;
  font-family: var(--sans);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  color: var(--ink);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.top-bar.hidden {
  transform: translateY(-100%);
}
.top-bar a {
  color: var(--ink);
  text-decoration: underline;
  text-underline-offset: 2px;
}
.nav-links { display: flex; gap: 36px; align-items: center; }
.nav-links a {
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: color 0.3s;
}
.nav.scrolled .nav-links a { color: var(--muted); }
.nav-links a:hover { color: var(--accent-text); }
.nav-cta {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  border: 1px solid rgba(255,255,255,0.4) !important;
  color: var(--white) !important;
  transition: all 0.3s !important;
}
.nav.scrolled .nav-cta {
  border-color: var(--accent-text) !important;
  color: var(--accent-text) !important;
}
.nav-cta:hover {}
.nav-login {
  font-size: 0.78rem !important;
  padding: 10px 24px;
  background: var(--accent) !important;
  color: var(--ink) !important;
  transition: all 0.3s !important;
}
.nav-login:hover {}
.nav-cta-apply { background: var(--accent) !important; border-color: var(--accent) !important; color: var(--ink) !important; }
.nav-cta-apply:hover { background: var(--accent-dark) !important; border-color: var(--accent-dark) !important; }
/* Keep the filled Apply Now button readable (dark ink on gold) when scrolled. */
.nav.scrolled .nav-cta-apply { background: var(--accent) !important; border-color: var(--accent) !important; color: var(--ink) !important; }
.nav-mobile { display: none; background: none; border: none; cursor: pointer; }
.nav-mobile span {
  display: block; width: 24px; height: 1.5px; background: var(--white);
  margin: 6px 0; transition: all 0.3s;
}
.nav.scrolled .nav-mobile span { background: var(--ink); }

/* ===== HERO ===== */
.hero {
  position: relative;
  height: 100vh;
  min-height: 700px;
  display: flex;
  align-items: flex-end;
  padding-bottom: clamp(60px, 10vh, 120px);
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; background-color: #1a1a18; z-index: 0; }
.hero-slide {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  opacity: 0; transition: opacity 1.4s ease-in-out;
}
.hero-slide.is-active { opacity: 1; }
.hero-overlay {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background:
    linear-gradient(180deg, rgba(20,18,16,0.62) 0%, rgba(20,18,16,0.34) 42%, rgba(20,18,16,0.92) 100%),
    linear-gradient(90deg, rgba(20,18,16,0.45) 0%, rgba(20,18,16,0) 55%);
}
.hero .container { position: relative; z-index: 2; width: 100%; }
.hero-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.8s 0.3s forwards;
}
.hero-tag::before {
  content: '';
  width: 40px; height: 1px;
  background: var(--accent);
}
.hero h1 {
  font-family: var(--serif);
  font-size: clamp(2.8rem, 6vw, 5.5rem);
  font-weight: 300;
  line-height: 1.08;
  color: var(--white);
  max-width: 800px;
  margin-bottom: 28px;
  opacity: 0;
  animation: fadeUp 0.8s 0.5s forwards;
}
.hero h1 em {
  font-style: italic;
  font-weight: 300;
  color: var(--accent);
}
.hero-sub {
  font-size: clamp(0.95rem, 1.3vw, 1.1rem);
  font-weight: 300;
  line-height: 1.7;
  color: rgba(255,255,255,0.65);
  max-width: 520px;
  margin-bottom: 44px;
  opacity: 0;
  animation: fadeUp 0.8s 0.7s forwards;
}
.hero-actions {
  display: flex; gap: 16px; flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.8s 0.9s forwards;
}
.btn-primary {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 36px;
  background: var(--accent);
  color: var(--ink);
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.btn-primary:hover {}
.btn-primary svg { transition: transform 0.3s; }
.btn-outline {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 16px 36px;
  background: transparent;
  color: var(--white);
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  border: 1px solid rgba(255,255,255,0.3);
  cursor: pointer;
  transition: all 0.4s;
}
.btn-outline:hover {}

/* Side stats — align the right edge to the centered 1280px content container
   (not the viewport edge) so they line up with the nav, headline and buttons. */
.hero-stats {
  position: absolute;
  right: calc(max(0px, (100vw - 1280px) / 2) + clamp(24px, 5vw, 80px));
  bottom: clamp(60px, 10vh, 120px);
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 32px;
  opacity: 0;
  animation: fadeUp 0.8s 1.1s forwards;
}
.hero-stat {
  text-align: right;
}
.hero-stat-num {
  font-family: var(--serif);
  font-size: 2.4rem;
  font-weight: 300;
  color: var(--white);
  line-height: 1;
}
.hero-stat-label {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  margin-top: 10px;
}

/* ===== MARQUEE ===== */
.marquee-section {
  padding: 12px 0;
  background: var(--ink);
  overflow: hidden;
}
.marquee-track {
  display: flex;
  animation: marquee 45s linear infinite;
  width: max-content;
}
.marquee-item {
  display: flex; align-items: center; gap: 12px;
  padding: 0 28px;
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 400;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.35);
  white-space: nowrap;
}
.marquee-avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.marquee-avatar img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center 20%;
}
.marquee-item::after {
  content: '\2726';
  font-size: 0.5rem;
  color: var(--accent);
  opacity: 0.6;
}
@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ===== FEATURED PREVIEW ===== */
.featured-preview {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--cream);
}
.fp-title {
  font-family: var(--serif);
  font-size: clamp(1.8rem, 3vw, 2.8rem);
  font-weight: 300;
  text-align: center;
  margin-bottom: 32px;
}
.fp-city-links {
  display: flex;
  justify-content: center;
  gap: 28px;
  margin-bottom: clamp(32px, 4vw, 48px);
  flex-wrap: wrap;
}
.fp-city-link {
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s;
  background: none;
  border: none;
  padding: 0;
  white-space: nowrap;
}
.fp-city-link:hover { color: var(--ink); }
.fp-city-link.active {
  color: var(--ink);
  font-weight: 600;
  text-decoration: underline;
  text-underline-offset: 4px;
  text-decoration-thickness: 1px;
}
.fp-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}
.fp-empty-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: clamp(48px, 6vw, 80px) 24px;
  color: var(--muted);
}
.fp-empty-state p {
  font-family: var(--serif);
  font-size: clamp(1.2rem, 2vw, 1.5rem);
  font-weight: 300;
  color: var(--muted);
  margin-bottom: 4px;
}
.fp-card {
  background: var(--white);
  border-radius: 0;
  overflow: hidden;
  cursor: pointer;
}
.fp-card-img {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
}
.fp-card-slides {
  display: flex;
  width: 100%; height: 100%;
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}
.fp-card-img-inner {
  flex: 0 0 100%;
  width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
}
/* Desktop: second image on hover (crossfade) */
@media (min-width: 769px) {
  .fp-card-slides {
    transition: none;
  }
  .fp-card-img-inner {
    position: absolute;
    top: 0; left: 0;
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .fp-card-img-inner:first-child {
    position: relative;
    opacity: 1;
  }
  .fp-card:hover .fp-card-img-inner:first-child {
    opacity: 0;
  }
  .fp-card:hover .fp-card-img-inner:nth-child(2) {
    opacity: 1;
  }
}
/* Dots: hidden by default (desktop), shown on mobile */
.fp-slide-dots {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  display: none;
  gap: 4px;
  z-index: 3;
}
.fp-slide-dot {
  width: 20px; height: 2.5px;
  border-radius: 1px;
  background: rgba(255,255,255,0.4);
  transition: all 0.3s;
}
.fp-slide-dot.active {
  background: var(--white);
}
@media (max-width: 768px) {
  .fp-slide-dots { display: flex; }
}
.fp-card-badge {
  position: absolute;
  top: 12px; left: 12px;
  padding: 5px 12px;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  background: var(--ink);
  color: var(--white);
  border-radius: 0;
}
.fp-card-badge.badge-just-listed {
  background: var(--accent);
  color: var(--ink);
}
.fp-card-dots {
  position: absolute;
  bottom: 12px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 5px;
}
.fp-dot {
  width: 6px; height: 6px;
  border-radius: 0;
  background: rgba(255,255,255,0.5);
}
.fp-dot.active { background: var(--white); }
.fp-card-info {
  padding: 18px 20px 22px;
}
.fp-card-info h3 {
  font-family: var(--sans);
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--ink);
  line-height: 1.35;
  min-height: 2.7em; /* reserve two lines so the meta row aligns across cards */
  margin-bottom: 6px;
}
.fp-card-details {
  font-size: 0.8rem;
  font-weight: 400;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 2px;
  flex-wrap: wrap;
}
.fp-card-details svg {
  vertical-align: middle;
  margin-top: -1px;
}
.fp-cta {
  text-align: center;
  margin-top: clamp(32px, 4vw, 48px);
}
.fp-browse-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  font-family: var(--sans);
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--ink);
  background: var(--accent);
  border-radius: 0;
  text-decoration: none;
  transition: all 0.3s;
}
.fp-browse-link:hover {
  background: var(--accent);
}

/* ===== TESTIMONIAL BANNER ===== */
.testimonial-banner {
  padding: 28px 0;
  background: var(--ink);
}
.testimonial-banner .container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.tb-arrow {
  flex-shrink: 0;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  transition: opacity 0.3s;
}
.tb-arrow:hover { opacity: 0.6; }
.tb-arrow svg { width: 16px; height: 16px; }
.tb-slide-area {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}
.tb-slide {
  display: flex;
  align-items: center;
  gap: 20px;
}
.tb-author {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
}
.tb-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.tb-avatar svg {
  width: 18px; height: 18px;
  fill: rgba(255,255,255,0.4);
}
.tb-avatar img {
  width: 100%; height: 100%;
  border-radius: 50%;
  object-fit: cover;
}
.tb-name {
  font-family: var(--sans);
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--white);
  white-space: nowrap;
}
.tb-stars {
  display: flex;
  gap: 2px;
  flex-shrink: 0;
}
.tb-stars svg {
  width: 11px; height: 11px;
  fill: var(--accent);
}
.tb-text {
  font-family: var(--serif);
  font-size: 0.95rem;
  font-weight: 300;
  font-style: italic;
  color: rgba(255,255,255,0.8);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tb-link {
  flex-shrink: 0;
  font-family: var(--sans);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink);
  background: var(--accent);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  transition: opacity 0.3s;
}
.tb-link:hover { opacity: 1; }
@media (max-width: 768px) {
  .testimonial-banner .container { gap: 12px; }
  .tb-slide { flex-wrap: wrap; gap: 10px; }
  .tb-text { white-space: normal; font-size: 0.85rem; }
}

/* ===== ABOUT BRIEF ===== */
.about-brief {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--white);
}
.about-brief-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: clamp(40px, 6vw, 100px);
  align-items: start;
}
.about-brief-left {}
.section-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent-text);
  margin-bottom: 24px;
}
.section-tag::before {
  content: '';
  width: 32px; height: 1px;
  background: var(--accent-text);
}
.about-brief-left h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
  margin-bottom: 32px;
}
.about-brief-left h2 em {
  font-style: italic;
  color: var(--accent-text);
}
.about-brief-right p {
  font-size: 1rem;
  font-weight: 300;
  line-height: 1.85;
  color: var(--muted);
  margin-bottom: 20px;
}
.about-brief-right p:first-child {
  font-size: 1.15rem;
  color: var(--ink);
  font-weight: 400;
}
.divider-line {
  width: 40px; height: 1px;
  background: var(--accent);
  margin: 36px 0;
}
.about-metrics {
  display: flex; gap: 48px; margin-top: 40px;
}
.about-metric h4 {
  font-family: var(--serif);
  font-size: 2.2rem;
  font-weight: 300;
  color: var(--ink);
  line-height: 1;
}
.about-metric p {
  font-size: 0.72rem !important;
  font-weight: 600 !important;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted) !important;
  margin-top: 6px !important;
}
.about-pillars {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 8px;
}
.about-pillar {
  padding: 22px 0;
  border-bottom: 1px solid rgba(196,189,179,0.3);
}
.about-pillar:first-child {
  border-top: 1px solid rgba(196,189,179,0.3);
}
.about-pillar h4 {
  font-family: var(--serif);
  font-size: 1.2rem;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 8px;
}
.about-pillar p {
  font-size: 0.9rem !important;
  font-weight: 300 !important;
  line-height: 1.7;
  color: var(--muted) !important;
  margin-bottom: 0 !important;
}

/* ===== WHY CHOOSE HIVE ===== */
.why-choose-hive {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--ink);
  position: relative;
  overflow: hidden;
}
.why-choose-hive::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background:
    radial-gradient(ellipse 60% 50% at 20% 30%, rgba(230,210,0,0.06) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 70%, rgba(230,210,0,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.wch-header {
  text-align: center;
  margin-bottom: clamp(48px, 6vw, 72px);
  position: relative;
}
.wch-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
  color: var(--white);
}
.wch-header h2 em { font-style: italic; color: var(--accent); }
.wch-header p {
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255,255,255,0.5);
  max-width: 560px;
  margin: 20px auto 0;
  line-height: 1.7;
}
.wch-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 0;
  position: relative;
}
.wch-card {
  padding: clamp(32px, 3vw, 48px);
  border-right: 1px solid rgba(255,255,255,0.06);
  transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  position: relative;
}
.wch-card:last-child { border-right: none; }
.wch-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 0; height: 2px;
  background: var(--accent);
  transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.wch-card:hover::after { width: 60%; }
.wch-card:hover { background: rgba(255,255,255,0.03); }
.wch-num {
  font-family: var(--serif);
  font-size: 3rem;
  font-weight: 300;
  color: var(--accent);
  opacity: 0.3;
  line-height: 1;
  margin-bottom: 24px;
}
.wch-card h3 {
  font-family: var(--serif);
  font-size: 1.4rem;
  font-weight: 400;
  color: var(--white);
  margin-bottom: 16px;
}
.wch-card p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.75;
  color: rgba(255,255,255,0.5);
}
.wch-bottom {
  margin-top: clamp(48px, 6vw, 72px);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 48px;
  position: relative;
}
.wch-bottom-stat {
  text-align: center;
}
.wch-bottom-stat h4 {
  font-family: var(--serif);
  font-size: 2.4rem;
  font-weight: 300;
  color: var(--accent);
  line-height: 1;
}
.wch-bottom-stat p {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-top: 6px;
}
.wch-divider {
  width: 1px; height: 40px;
  background: rgba(255,255,255,0.1);
}
@media (max-width: 1024px) {
  .wch-grid { grid-template-columns: repeat(2, 1fr); }
  .wch-card { border-bottom: 1px solid rgba(255,255,255,0.06); }
  .wch-card:nth-child(2) { border-right: none; }
}
@media (max-width: 768px) {
  .wch-grid { grid-template-columns: 1fr; }
  .wch-card { border-right: none; }
  .wch-bottom { flex-wrap: wrap; gap: 32px; }
  .wch-divider { display: none; }
}

/* ===== WHY CHOOSE US ===== */
.why-section {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--cream);
  position: relative;
}
.why-section::before {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 40%; height: 100%;
  background: radial-gradient(ellipse at 100% 0%, rgba(230,210,0,0.05) 0%, transparent 60%);
}
.why-header {
  text-align: center;
  margin-bottom: clamp(48px, 6vw, 80px);
  position: relative;
}
.why-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
}
.why-header h2 em { font-style: italic; color: var(--accent-text); }
.why-header p {
  font-size: 1rem;
  font-weight: 300;
  color: var(--muted);
  max-width: 540px;
  margin: 20px auto 0;
  line-height: 1.7;
}
.why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--stone);
  border: 1px solid var(--stone);
  position: relative;
}
.why-card {
  padding: clamp(28px, 3vw, 40px);
  background: var(--white);
}
.why-card h3 {
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 400;
  margin-bottom: 10px;
}
.why-card p {
  font-size: 0.88rem;
  font-weight: 300;
  line-height: 1.7;
  color: var(--muted);
}

/* ===== PROPERTIES ===== */
.properties-section {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--white);
}
.properties-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: clamp(40px, 5vw, 64px);
}
.properties-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
}
.properties-header h2 em { font-style: italic; color: var(--accent-text); }
.properties-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}
.property-card {
  position: relative;
  cursor: pointer;
  group: true;
}
.property-img {
  position: relative;
  aspect-ratio: 3/3.5;
  overflow: hidden;
  margin-bottom: 20px;
}
.property-img-inner {
  width: 100%; height: 100%;
  background-size: cover;
  background-position: center;
  transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
}
.property-card:hover .property-img-inner {
  transform: scale(1.05);
}
.property-img-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, transparent 50%, rgba(26,26,24,0.4) 100%);
  opacity: 0;
  transition: opacity 0.4s;
}
.property-card:hover .property-img-overlay { opacity: 1; }
.property-badge {
  position: absolute;
  top: 16px; left: 16px;
  padding: 6px 14px;
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.badge-available {
  background: var(--accent);
  color: var(--ink);
}
.badge-just-listed {
  background: var(--accent);
  color: var(--ink);
}
.badge-soon {
  background: var(--ink);
  color: var(--white);
}
.property-price {
  position: absolute;
  bottom: 16px; right: 16px;
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 400;
  color: var(--white);
  opacity: 0;
  transform: translateY(8px);
  transition: all 0.4s;
}
.property-card:hover .property-price {
  opacity: 1; transform: translateY(0);
}
.property-price span {
  font-family: var(--sans);
  font-size: 0.7rem;
  font-weight: 400;
  color: rgba(255,255,255,0.7);
}
.property-info h3 {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 400;
  margin-bottom: 6px;
}
.property-meta {
  display: flex; align-items: center; gap: 16px;
  font-size: 0.78rem;
  font-weight: 400;
  color: var(--muted);
}
.property-meta span {
  display: flex; align-items: center; gap: 5px;
}
.property-meta .dot {
  width: 3px; height: 3px;
  border-radius: 0;
  background: var(--stone);
}

/* Browse bar */
.browse-bar {
  margin-top: clamp(48px, 5vw, 72px);
  padding: clamp(28px, 3vw, 44px);
  background: var(--cream);
  display: flex;
  gap: 20px;
  align-items: flex-end;
}
.browse-field {
  flex: 1;
}
.browse-field label {
  display: block;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 10px;
}
.browse-field select,
.browse-field input {
  width: 100%;
  padding: 14px 16px;
  font-family: var(--sans);
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--ink);
  background: var(--white);
  border: 1px solid var(--stone);
  appearance: none;
  -webkit-appearance: none;
  outline: none;
  cursor: pointer;
  transition: border-color 0.3s;
}
.browse-field select:focus,
.browse-field input:focus {
  border-color: var(--accent);
}
.browse-field select {
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%238a8378' stroke-width='1.2'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 16px center;
  padding-right: 40px;
}
.browse-btn {
  padding: 14px 40px;
  background: var(--ink);
  color: var(--white);
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: all 0.3s;
  white-space: nowrap;
}
.browse-btn:hover {}

/* ===== TESTIMONIALS ===== */
.testimonials-section {
  padding: clamp(48px, 6vw, 80px) 0;
  background: var(--white);
  position: relative;
  overflow: hidden;
}
.testimonials-section::before {
  content: '\201C';
  position: absolute;
  top: -40px; right: 5%;
  font-family: var(--serif);
  font-size: 28rem;
  font-weight: 300;
  color: rgba(0,0,0,0.02);
  line-height: 1;
  pointer-events: none;
}
.testimonials-header {
  margin-bottom: clamp(48px, 6vw, 80px);
}
.testimonials-header .section-tag { color: var(--accent-text); }
.testimonials-header .section-tag::before { background: var(--accent-text); }
.testimonials-header h2 {
  font-family: var(--serif);
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  font-weight: 300;
  line-height: 1.15;
  color: var(--ink);
}
.testimonials-header h2 em { font-style: italic; color: var(--accent-text); }
.testimonials-grid {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
