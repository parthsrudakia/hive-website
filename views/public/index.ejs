    grid-template-columns: 1fr;
  }
  .fp-grid .fp-card:last-child { display: block; }
  .fp-city-links {
    flex-wrap: nowrap;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    justify-content: flex-start;
    padding-bottom: 4px;
    gap: 20px;
  }
  .fp-city-links::-webkit-scrollbar { display: none; }
  .fp-cta { margin-top: 24px; }
  .nav-links { display: none; }
  .nav-mobile { display: block; }
  .about-brief-inner { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; }
  .properties-header { flex-direction: column; align-items: flex-start; gap: 20px; }
  .properties-grid { grid-template-columns: 1fr; }
  .testimonial-card { flex: 0 0 280px; }
  .faq-inner { grid-template-columns: 1fr; }
  .faq-header { position: static; margin-bottom: 32px; }
  .partners-inner { grid-template-columns: 1fr; }
  .partners-visual { min-height: 300px; }
  .footer-top { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 12px; text-align: center; }
  .browse-bar { flex-direction: column; }
  .browse-field { min-width: 100%; }
  .about-metrics { gap: 32px; }
}
</style>
